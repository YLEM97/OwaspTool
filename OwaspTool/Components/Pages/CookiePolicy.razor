@page "/cookie-policy"
<PageTitle>Cookie Policy — CureCode</PageTitle>

<div class="cc-policy-page">

    <!-- HEADER -->
    <div class="cc-policy-header">
        <div class="cc-policy-header-icon">
            <MudIcon Icon="@Icons.Material.Filled.Cookie" Style="font-size:1.8rem; color:#34acd8;" />
        </div>
        <h1 class="cc-policy-title">
            <span class="cc-policy-brand">CureCode</span> Cookie Policy
        </h1>
        <p class="cc-policy-subtitle">Last update: <em>2025/11/05</em></p>
    </div>

    <!-- SECTIONS -->
    <div class="cc-policy-content">

        <!-- 1 -->
        <section class="cc-policy-section">
            <h2 class="cc-policy-section-title">1. What are Cookies?</h2>
            <p class="cc-policy-text">
                Cookies are small text files that are stored on your device (computer, tablet, or mobile phone) when you visit a website.
                They help the website remember your preferences and improve your browsing experience.
            </p>
        </section>

        <!-- 2 -->
        <section class="cc-policy-section">
            <h2 class="cc-policy-section-title">2. Types of cookies we use</h2>

            <div class="cc-policy-table-wrap">
                <table class="cc-policy-table">
                    <thead>
                        <tr>
                            <th>Type of cookies</th>
                            <th>Purpose</th>
                            <th>Mandatory</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cookie in cookiesList)
                        {
                            <tr>
                                <td class="cc-policy-td-bold">@cookie.Type</td>
                                <td>@cookie.Purpose</td>
                                <td>
                                    @if (cookie.Mandatory == "Yes")
                                    {
                                        <span class="cc-policy-badge cc-policy-badge--yes">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="cc-policy-badge cc-policy-badge--no">No</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <p class="cc-policy-text cc-policy-text--label">Cookies we do <strong>not</strong> use:</p>
            <ul class="cc-policy-list">
                <li>Advertising cookies</li>
                <li>Profiling cookies</li>
                <li>Third-party tracking cookies for marketing</li>
            </ul>
        </section>

        <!-- 3 -->
        <section class="cc-policy-section">
            <h2 class="cc-policy-section-title">3. Personal data we collect during registration</h2>
            <p class="cc-policy-text">If you create an account on this website, we store the following personal data:</p>
            <ul class="cc-policy-list">
                <li>First name</li>
                <li>Last name</li>
                <li>Email address</li>
            </ul>
            <p class="cc-policy-text">
                These are stored only in our authentication database to allow you to register, log in and access our services.
            </p>
        </section>

        <!-- 4 -->
        <section class="cc-policy-section">
            <h2 class="cc-policy-section-title">4. How long do cookies last?</h2>
            <ul class="cc-policy-list">
                <li>Session cookies are deleted automatically when you close your browser.</li>
                <li>Preference cookies can remain stored to remember your consent choice, unless deleted manually in your browser.</li>
            </ul>
        </section>

        <!-- 5 -->
        <section class="cc-policy-section">
            <h2 class="cc-policy-section-title">5. How to change or withdraw consent</h2>
            <p class="cc-policy-text">
                You can change your cookie preferences at any time using the cookie consent banner or via your browser settings.
            </p>
        </section>

        <!-- 6 -->
        <section class="cc-policy-section">
            <h2 class="cc-policy-section-title">6. Contact</h2>
            <p class="cc-policy-text">
                If you have any questions about this Cookie Policy or about personal data processing, please contact us at:
                <a href="mailto:ylenia.murgia@edu.unige.it" class="cc-policy-link">ylenia.murgia@@edu.unige.it</a>
            </p>
        </section>

    </div>
</div>

@code {
    public record CureCodeCookies(string Type, string Purpose, string Mandatory);

    private List<CureCodeCookies> cookiesList = new()
    {
        new CureCodeCookies(
            "Strictly necessary and session cookies",
            "Required to operate the website and to maintain your login session. Without them, the site cannot function properly.",
            "Yes"),
        new CureCodeCookies(
            "Persistent cookies",
            "Used to remember your cookie preferences and settings on this website.",
            "No")
    };
}
