@page "/asvs-requirements"
@using OwaspTool.DAL
@using Microsoft.EntityFrameworkCore
@inject OwaspToolContext DbContext
@inject NavigationService NavService
@rendermode InteractiveServer

<PageTitle>ASVS Requirements — CureCode</PageTitle>

<div class="cc-asvs-page">

    <!-- HEADER -->
    <div class="cc-asvs-header">
        <div class="cc-asvs-header-icon">
            <MudIcon Icon="@Icons.Material.Filled.Security" Style="font-size: 2rem; color: #34acd8;" />
        </div>
        <h1 class="cc-asvs-header-title">OWASP ASVS Requirements <span class="cc-asvs-version-badge">v5.0</span></h1>
        <p class="cc-asvs-header-subtitle">Application Security Verification Standard — Comprehensive Requirements Matrix</p>

        @if (GroupedRequirements != null)
        {
            <div class="cc-asvs-stats">
                <div class="cc-asvs-stat">
                    <span class="cc-asvs-stat-number">@GroupedRequirements.Count</span>
                    <span class="cc-asvs-stat-label">Chapters</span>
                </div>
                <div class="cc-asvs-stat-divider"></div>
                <div class="cc-asvs-stat">
                    <span class="cc-asvs-stat-number">@GroupedRequirements.SelectMany(c => c.Value).Count()</span>
                    <span class="cc-asvs-stat-label">Sections</span>
                </div>
                <div class="cc-asvs-stat-divider"></div>
                <div class="cc-asvs-stat">
                    <span class="cc-asvs-stat-number">@GroupedRequirements.SelectMany(c => c.Value).SelectMany(s => s.Value).Count()</span>
                    <span class="cc-asvs-stat-label">Requirements</span>
                </div>
            </div>
        }
    </div>

    <!-- CONTENT -->
    <div class="cc-asvs-content">
        @if (GroupedRequirements == null)
        {
            <div class="cc-asvs-loading">
                <MudProgressCircular Indeterminate="true" Style="color: #34acd8;" Size="Size.Large" />
                <span>Loading ASVS Requirements...</span>
            </div>
        }
        else
        {
            <MudExpansionPanels Elevation="0" Class="cc-asvs-chapters">
                @foreach (var chapter in GroupedRequirements.OrderBy(c => c.Key.ChapterID))
                {
                    <MudExpansionPanel Class="cc-asvs-chapter-panel" DisableRipple="true">
                        <TitleContent>
                            <div class="cc-asvs-chapter-title">
                                <div class="cc-asvs-chapter-icon">
                                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Style="font-size: 1.1rem;" />
                                </div>
                                <span class="cc-asvs-chapter-name">@chapter.Key.Number — @chapter.Key.Title</span>
                                <MudSpacer />
                                <span class="cc-asvs-count-badge">
                                    @chapter.Value.SelectMany(s => s.Value).Count() requirements
                                </span>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudExpansionPanels Elevation="0" ExpandMultiple="true" Class="cc-asvs-sections">
                                @foreach (var section in chapter.Value.OrderBy(s => s.Key.SectionID))
                                {
                                    <MudExpansionPanel Class="cc-asvs-section-panel" Dense="true" DisableRipple="true">
                                        <TitleContent>
                                            <div class="cc-asvs-section-title">
                                                <MudIcon Icon="@Icons.Material.Filled.Article"
                                                         Style="font-size: 1rem; margin-right: 10px; color: #7483f3;" />
                                                <span>@($"{section.Key.Number} - {section.Key.Title}")</span>
                                                <MudSpacer />
                                                <span class="cc-asvs-count-badge cc-asvs-count-badge--purple">
                                                    @(section.Value.Count) requirements
                                                </span>
                                            </div>
                                        </TitleContent>
                                        <ChildContent>
                                            @{
                                                var requirements = section.Value.OrderBy(r => r.ASVSRequirementID).ToList();
                                            }
                                            @if (requirements.Count > 0)
                                            {
                                                <div class="cc-asvs-requirements-list">
                                                    @foreach (var req in requirements)
                                                    {
                                                        <div class="cc-asvs-requirement-row">
                                                            <span class="cc-asvs-req-number">@req.Number</span>
                                                            <span class="cc-asvs-req-text">@req.Text</span>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="cc-asvs-empty">
                                                    <MudIcon Icon="@Icons.Material.Filled.Info"
                                                             Style="color: #34acd8; font-size: 1.2rem;" />
                                                    <span>No requirements available in this section</span>
                                                </div>
                                            }
                                        </ChildContent>
                                    </MudExpansionPanel>
                                }
                            </MudExpansionPanels>
                        </ChildContent>
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
    </div>
</div>

@code {
    private Dictionary<ChapterDTO, Dictionary<SectionDTO, List<RequirementDTO>>>? GroupedRequirements;

    protected override async Task OnInitializedAsync()
    {
        var requirements = await DbContext.ASVSRequirements
            .Include(r => r.Chapter)
            .Include(r => r.Section)
            .ToListAsync();

        var requirementDTOs = requirements.Select(r => new RequirementDTO(r)).ToList();

        GroupedRequirements = requirementDTOs
            .GroupBy(r => r.Chapter!)
            .ToDictionary(
                g => g.Key,
                g => g.GroupBy(r => r.Section!)
                      .ToDictionary(sg => sg.Key, sg => sg.ToList())
            );
    }
}
