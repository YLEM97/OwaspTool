@page "/survey/{userWebAppId:int}/requirements"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using OwaspTool.DAL
@using OwaspTool.DTOs
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Hosting
@using Microsoft.Extensions.Hosting
@using MudBlazor
@using System.Security.Claims
@using System.Linq
@inject ISurveyRequirementsRepository RequirementsRepo
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject IWebHostEnvironment Env

<PageTitle>Survey Requirements — CureCode</PageTitle>

<div class="cc-sreq-page">

    <!-- HEADER -->
    <div class="cc-sreq-header">
        <div class="cc-sreq-header-icon">
            <MudIcon Icon="@Icons.Material.Filled.ListAlt" Style="font-size:1.8rem; color:#34acd8;" />
        </div>
        <h1 class="cc-sreq-header-title">
            <span class="cc-sreq-brand">CureCode</span>: Survey Requirements
        </h1>
        <p class="cc-sreq-header-subtitle">
            OWASP ASVS requirements derived from your survey answers
        </p>

        @if (Requirements != null && Requirements.Any())
        {
            <div class="cc-sreq-stats">
                <div class="cc-sreq-stat">
                    <span class="cc-sreq-stat-number">@GroupedRequirements.Count</span>
                    <span class="cc-sreq-stat-label">Chapters</span>
                </div>
                <div class="cc-sreq-stat-divider"></div>
                <div class="cc-sreq-stat">
                    <span class="cc-sreq-stat-number">@GroupedRequirements.SelectMany(c => c.Value).Count()</span>
                    <span class="cc-sreq-stat-label">Sections</span>
                </div>
                <div class="cc-sreq-stat-divider"></div>
                <div class="cc-sreq-stat">
                    <span class="cc-sreq-stat-number">@Requirements.Count</span>
                    <span class="cc-sreq-stat-label">Requirements</span>
                </div>
            </div>
        }
    </div>

    <!-- STATES -->
    @if (IsLoading)
    {
        <div class="cc-sreq-loading">
            <MudProgressCircular Indeterminate="true" Style="color:#34acd8;" Size="Size.Large" />
            <span>Loading ASVS Requirements...</span>
        </div>
    }
    else if (!CheckedAccess)
    {
        <div class="cc-sreq-loading">
            <MudProgressCircular Indeterminate="true" Style="color:#7483f3;" Size="Size.Medium" />
            <span>Checking access...</span>
        </div>
    }
    else if (!HasAccess)
    {
        <div class="cc-sreq-state-box">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size:2.5rem; color:rgba(231,111,81,0.7);" />
            <p class="cc-sreq-state-text">You do not have permission to view these requirements.</p>
            <button class="cc-sreq-btn cc-sreq-btn--outline" @onclick="GoBack">
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size:1rem;" /> Back
            </button>
        </div>
    }
    else if (Requirements == null || !Requirements.Any())
    {
        <div class="cc-sreq-state-box">
            <MudIcon Icon="@Icons.Material.Filled.AssignmentLate" Style="font-size:2.5rem; color:rgba(52,172,216,0.5);" />
            <p class="cc-sreq-state-text">Please complete the survey to view the OWASP ASVS requirements.</p>
            <button class="cc-sreq-btn cc-sreq-btn--outline" @onclick="GoBack">
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size:1rem;" /> Back
            </button>
        </div>
    }
    else
    {
        <!-- TOOLBAR -->
        <div class="cc-sreq-toolbar">
            <a class="cc-sreq-btn cc-sreq-btn--primary"
               href="@($"/download-requirements/{userWebAppId}")"
               target="_blank">
                <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Style="font-size:1rem;" />
                Download PDF
            </a>
            <button class="cc-sreq-btn cc-sreq-btn--secondary"
                    @onclick="@(() => NavigationManager.NavigateTo($"/survey/{userWebAppId}/implementation-status"))">
                <MudIcon Icon="@Icons.Material.Filled.Assessment" Style="font-size:1rem;" />
                Implementation Status
            </button>
        </div>

        <!-- CHAPTERS -->
        <div class="cc-sreq-content">
            <MudExpansionPanels Elevation="0" Class="cc-sreq-chapters">
                @foreach (var chapter in GroupedRequirements.OrderBy(c => c.Key.ChapterID))
                {
                    @if (VisibleChapters.Contains(chapter.Key.ChapterID))
                    {
                        <MudExpansionPanel Class="cc-asvs-chapter-panel" DisableRipple="true">
                            <TitleContent>
                                <div class="cc-asvs-chapter-title">
                                    <div class="cc-asvs-chapter-icon">
                                        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Style="font-size:1.1rem;" />
                                    </div>
                                    <span class="cc-asvs-chapter-name">@chapter.Key.Number — @chapter.Key.Title</span>
                                    <MudSpacer />
                                    <span class="cc-asvs-count-badge">
                                        @chapter.Value.Count() sections · @chapter.Value.SelectMany(s => s.Value).Count() requirements
                                    </span>
                                </div>
                            </TitleContent>
                            <ChildContent>
                                <MudExpansionPanels Elevation="0" ExpandMultiple="true" Class="cc-asvs-sections">
                                    @foreach (var section in chapter.Value.OrderBy(s => s.Key.SectionID))
                                    {
                                        <MudExpansionPanel Class="cc-asvs-section-panel" Dense="true" DisableRipple="true">
                                            <TitleContent>
                                                <div class="cc-asvs-section-title">
                                                    <MudIcon Icon="@Icons.Material.Filled.Article"
                                                             Style="font-size:1rem; margin-right:10px; color:#7483f3;" />
                                                    <span class="cc-sreq-section-label">
                                                        @($"{section.Key.Number} - {section.Key.Title}")
                                                    </span>
                                                    <MudSpacer />
                                                    <span class="cc-asvs-count-badge cc-asvs-count-badge--purple">
                                                        @(section.Value.Count()) requirements
                                                    </span>
                                                    <div @onclick:stopPropagation class="cc-sreq-save-wrap">
                                                        <button class="cc-sreq-btn cc-sreq-btn--save"
                                                                @onclick="@(() => SaveSectionStatuses(section.Key.SectionID))"
                                                                disabled="@(SectionSavingStates.TryGetValue(section.Key.SectionID, out var sv) && sv)">
                                                            @if (SectionSavingStates.TryGetValue(section.Key.SectionID, out var isSaving) && isSaving)
                                                            {
                                                                <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                                                     Style="color:#07193e; width:14px; height:14px;" />
                                                                <span>Saving...</span>
                                                            }
                                                            else
                                                            {
                                                                <MudIcon Icon="@Icons.Material.Filled.Save" Style="font-size:0.95rem;" />
                                                                <span>Save status</span>
                                                            }
                                                        </button>
                                                    </div>
                                                </div>
                                            </TitleContent>
                                            <ChildContent>
                                                @{
                                                    var reqs = section.Value.OrderBy(r => r.ASVSRequirementID).ToList();
                                                }
                                                @if (reqs.Count > 0)
                                                {
                                                    <div class="cc-sreq-list-wrap">
                                                        <Virtualize Items="reqs" ItemSize="200" Context="req">
                                                            <ItemContent>
                                                                @{
                                                                    var r = req;
                                                                }
                                                                <div class="cc-sreq-req-row">

                                                                    <!-- RIGA 1: numero - testo - ask ai - badge -->
                                                                    <div class="cc-sreq-row-top">

                                                                        <span class="cc-asvs-req-number cc-sreq-req-num">@r.Number</span>

                                                                        <span class="cc-asvs-req-text cc-sreq-req-txt">@r.Text</span>

                                                                        <div class="cc-sreq-row-top-actions">
                                                                            @if (ShowAiFeatures)
                                                                            {
                                                                                <button class="cc-sreq-ai-btn"
                                                                                        @onclick="@(() => OpenAiForRequirementAsync(r))">
                                                                                    <MudIcon Icon="@Icons.Material.Filled.SmartToy"
                                                                                             Style="font-size:0.9rem;" />
                                                                                    Ask AI
                                                                                </button>
                                                                            }
                                                                            @if (!string.IsNullOrWhiteSpace(r.Notes))
                                                                            {
                                                                                <span class="cc-sreq-note-badge">📝 Notes</span>
                                                                            }
                                                                            @if (ShowAiFeatures && !string.IsNullOrWhiteSpace(r.AiNotes))
                                                                            {
                                                                                <span class="cc-sreq-note-badge cc-sreq-note-badge--ai">🤖 AI</span>
                                                                            }
                                                                        </div>
                                                                    </div>

                                                                    <!-- RIGA 2: status radio -->
                                                                    <div class="cc-sreq-row-status">
                                                                        <MudRadioGroup T="int?"
                                                                                       Value="@r.ImplementationStatus"
                                                                                       ValueChanged="@(v => OnStatusChanged(r, v))">
                                                                            <MudRadio T="int?" Value="1" Color="Color.Primary">Implemented</MudRadio>
                                                                            <MudRadio T="int?" Value="0" Color="Color.Secondary">Not implemented</MudRadio>
                                                                            <MudRadio T="int?" Value="2" Color="Color.Default">Not applicable</MudRadio>
                                                                        </MudRadioGroup>
                                                                    </div>

                                                                    <!-- RIGA 3: note personali - note AI -->
                                                                    <div class="cc-sreq-row-notes">
                                                                        <div class="cc-sreq-notes-wrap">
                                                                            <label class="cc-sreq-notes-label">Personal notes</label>
                                                                            <textarea class="cc-sreq-textarea"
                                                                                      placeholder="Add personal notes (optional)"
                                                                                      maxlength="2000"
                                                                                      @bind="r.Notes"
                                                                                      @bind:event="oninput"></textarea>
                                                                        </div>

                                                                        @if (ShowAiFeatures)
                                                                        {
                                                                            <div class="cc-sreq-notes-wrap">
                                                                                <label class="cc-sreq-notes-label cc-sreq-notes-label--ai">AI notes</label>
                                                                                <textarea class="cc-sreq-textarea cc-sreq-textarea--ai"
                                                                                          placeholder="AI conversation (optional)"
                                                                                          maxlength="4000"
                                                                                          @bind="r.AiNotes"
                                                                                          @bind:event="oninput"></textarea>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            </ItemContent>
                                                        </Virtualize>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="cc-asvs-empty">
                                                        <MudIcon Icon="@Icons.Material.Filled.Info"
                                                                 Style="color:#34acd8; font-size:1.2rem;" />
                                                        <span>No requirements available in this section</span>
                                                    </div>
                                                }
                                            </ChildContent>
                                        </MudExpansionPanel>
                                    }
                                </MudExpansionPanels>
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                    else
                    {
                        <div class="cc-sreq-chapter-placeholder">
                            Loading chapter <strong>@chapter.Key.Title</strong>...
                        </div>
                    }
                }
            </MudExpansionPanels>
        </div>
    }
</div>

@code {
    [Parameter] public int userWebAppId { get; set; }

    private bool IsLoading = true;
    private List<RequirementDTO>? Requirements;
    private bool HasAccess = false;
    private bool CheckedAccess = false;
    private string? _currentUserEmail;
    private bool _data_loaded = false;

    private Dictionary<int, bool> SectionSavingStates = new();
    private Dictionary<ChapterDTO, Dictionary<SectionDTO, List<RequirementDTO>>> GroupedRequirements = new();
    private HashSet<int> VisibleChapters = new();

    private bool ShowAiFeatures = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_data_loaded)
        {
            _data_loaded = true;
            ShowAiFeatures = Env?.IsDevelopment() == true;
            await LoadDataAsync();
            _ = RevealChaptersGraduallyAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        var sw = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            IsLoading = true;
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            string? email = null;
            if (user?.Identity != null && user.Identity.IsAuthenticated)
                email = user.FindFirst(ClaimTypes.Email)?.Value ?? user.FindFirst("email")?.Value;
            _currentUserEmail = email;

            var reqs = await RequirementsRepo.GetRequirementsForUserWebAppIfOwnerAsync(userWebAppId, email);
            if (reqs == null)
            {
                HasAccess = false;
                Requirements = new List<RequirementDTO>();
            }
            else
            {
                HasAccess = true;
                Requirements = reqs;
                GroupedRequirements = Requirements
                    .GroupBy(r => r.Chapter!)
                    .ToDictionary(
                        g => g.Key,
                        g => g.GroupBy(r => r.Section!)
                              .ToDictionary(sg => sg.Key, sg => sg.ToList())
                    );
                foreach (var chapter in GroupedRequirements.Values)
                    foreach (var section in chapter.Keys)
                        SectionSavingStates[section.SectionID] = false;
            }
            CheckedAccess = true;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"ERROR {ex.GetType().Name}: {ex.Message}");
            HasAccess = false;
            Requirements = new List<RequirementDTO>();
            CheckedAccess = true;
        }
        finally
        {
            IsLoading = false;
            sw.Stop();
            Console.WriteLine($"[TIMING] LoadDataAsync completed in {sw.ElapsedMilliseconds} ms");
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RevealChaptersGraduallyAsync(int delayPerChapterMs = 30)
    {
        try
        {
            foreach (var id in GroupedRequirements.Keys.Select(k => k.ChapterID).ToList())
            {
                VisibleChapters.Add(id);
                await InvokeAsync(StateHasChanged);
                await Task.Delay(delayPerChapterMs);
            }
        }
        catch (Exception ex) { Console.Error.WriteLine($"RevealChaptersGraduallyAsync: {ex.Message}"); }
    }

    private void GoBack() => NavigationManager.NavigateTo("/");

    private async Task SaveSectionStatuses(int sectionId)
    {
        SectionSavingStates[sectionId] = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var invalid = Requirements
                ?.Where(r => r.SectionID == sectionId && !string.IsNullOrWhiteSpace(r.Notes) && !r.ImplementationStatus.HasValue)
                .ToList();

            if (invalid != null && invalid.Any())
            {
                var ids = invalid.Select(x => x.Number ?? x.ASVSRequirementID.ToString()).ToList();
                var list = string.Join(", ", ids.Take(6)) + (ids.Count > 6 ? $" and {ids.Count - 6} more" : "");
                Snackbar.Add($"Set status before saving notes for: {list}.", Severity.Warning, c => c.VisibleStateDuration = 6000);
                SectionSavingStates[sectionId] = false;
                await InvokeAsync(StateHasChanged);
                return;
            }

            foreach (var req in Requirements!.Where(r => r.SectionID == sectionId && r.ImplementationStatus.HasValue))
                await RequirementsRepo.SaveRequirementStatusAsync(userWebAppId, req.ASVSRequirementID, req.ImplementationStatus!.Value, _currentUserEmail, req.Notes, req.AiNotes);

            Snackbar.Add("Status and notes saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error saving section {sectionId}: {ex.Message}");
            Snackbar.Add("Error saving. Please retry.", Severity.Error);
        }
        finally
        {
            SectionSavingStates[sectionId] = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnStatusChanged(RequirementDTO requirement, int? newStatus) =>
        requirement.ImplementationStatus = newStatus;

    private async Task OpenAiForRequirementAsync(RequirementDTO r)
    {
        if (!ShowAiFeatures) return;
        var parameters = new DialogParameters
        {
            { nameof(AiRequirementDialog.RequirementNumber), r.Number ?? r.ASVSRequirementID.ToString() },
            { nameof(AiRequirementDialog.RequirementText), r.Text ?? string.Empty }
        };
        var dialogRef = DialogService.Show<AiRequirementDialog>("AI Help", parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialogRef.Result;
        if (!(result?.Data is string conv) || string.IsNullOrWhiteSpace(conv)) return;

        if (string.IsNullOrWhiteSpace(r.AiNotes))
        {
            r.AiNotes = conv;
            Snackbar.Add("AI conversation pasted.", Severity.Info);
            await InvokeAsync(StateHasChanged);
            return;
        }

        var choiceRef = DialogService.Show<AiPasteChoiceDialog>("AI Paste Options",
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall });
        var choiceResult = await choiceRef.Result;
        if (!(choiceResult?.Data is string action)) return;

        switch (action)
        {
            case "replace":
                r.AiNotes = conv;
                Snackbar.Add("AI Notes replaced.", Severity.Success);
                break;
            case "append":
                r.AiNotes = r.AiNotes + "\n\n---\n\n" + $"(Appended {DateTime.UtcNow:yyyy-MM-dd HH:mm})\n\n" + conv;
                Snackbar.Add("Conversation appended to AI Notes.", Severity.Success);
                break;
        }
        await InvokeAsync(StateHasChanged);
    }
}
