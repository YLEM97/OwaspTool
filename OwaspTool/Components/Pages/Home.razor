@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Authorization
@using OwaspTool.Components.Shared
@inject AuthenticationStateProvider AuthProvider
@inject NavigationService NavService

<PageTitle>CureCode</PageTitle>

<HeroSection />

<!-- ===================== WELCOME SECTION ===================== -->
<section class="cc-welcome-section" id="welcome-section">
    <div class="cc-welcome-section-container">
        <h2 class="cc-welcome-section-title">
            Explore and Exploit
            <span class="cc-brand-word">
                <span class="cc-letter-welcome" style="color:#34acd8;">C</span>
                <span class="cc-letter-welcome" style="color:#34acd8;">u</span>
                <span class="cc-letter-welcome" style="color:#34acd8;">r</span>
                <span class="cc-letter-welcome" style="color:#34acd8;">e</span>
                <span class="cc-letter-welcome" style="color:#7483f3;">C</span>
                <span class="cc-letter-welcome" style="color:#7483f3;">o</span>
                <span class="cc-letter-welcome" style="color:#7483f3;">d</span>
                <span class="cc-letter-welcome pe-2" style="color:#7483f3;">e</span>
            </span>
            Potential
        </h2>
        <h5 class="cc-welcome-section-subtitle">
            Your smart assistant for secure by-design healthcare web development
        </h5>
        <p class="cc-welcome-section-content">
            CureCode helps healthcare developers apply security best practices with ease.
            Based on a quick survey, it generates tailored security requirements from the <b>OWASP ASVS 5.0</b> standard
            and surfaces the relevant <b>OWASP WSTG</b> tests to validate your healthcare web application, all in one place.
            <br />
            <br />
            <i>No guesswork, no lengthy documents — just clarity, compliance, and confidence.</i>
        </p>
        <MudButton Variant="Variant.Filled"
                   Class="cc-pulse-button"
                   OnClick="HandleGoToProfile">
            <b>Get Started</b>
        </MudButton>
    </div>
</section>

<SectionDivider />

<!-- ===================== WHY CHOOSE SECTION ===================== -->
<section class="cc-why-choose-section">
    <div class="cc-why-choose-section-header">
        <h2 class="cc-why-choose-section-title">
            Why choose
            <span class="cc-brand-word">
                <span class="cc-letter-welcome" style="color:#34acd8;">C</span>
                <span class="cc-letter-welcome" style="color:#34acd8;">u</span>
                <span class="cc-letter-welcome" style="color:#34acd8;">r</span>
                <span class="cc-letter-welcome" style="color:#34acd8;">e</span>
                <span class="cc-letter-welcome" style="color:#7483f3;">C</span>
                <span class="cc-letter-welcome" style="color:#7483f3;">o</span>
                <span class="cc-letter-welcome" style="color:#7483f3;">d</span>
                <span class="cc-letter-welcome" style="color:#7483f3;">e</span>
            </span>
            ?
        </h2>
        <div class="cc-why-stats">
            <div class="cc-why-stat">
                <span class="cc-why-stat-number">5<span class="cc-why-stat-suffix">min</span></span>
                <span class="cc-why-stat-label">Average setup time</span>
                <p class="cc-why-stat-desc">Answer a short questionnaire and instantly get requirements tailored to your app's architecture and risk level. Simple and efficient.</p>
            </div>
            <div class="cc-why-stat-divider"></div>
            <div class="cc-why-stat">
                <span class="cc-why-stat-number">2</span>
                <span class="cc-why-stat-label">Security frameworks</span>
                <p class="cc-why-stat-desc">Based on your answers, CureCode selects the most relevant items from both OWASP ASVS and WSTG, giving you a focused requirements checklist and a matching test list, each in a dedicated tab.</p>
            </div>
            <div class="cc-why-stat-divider"></div>
            <div class="cc-why-stat">
                <span class="cc-why-stat-number">0</span>
                <span class="cc-why-stat-label">Security Expertise Required</span>
                <p class="cc-why-stat-desc">CureCode is built for developers, not security specialists. Just answer a short questionnaire about your application and let the platform generate a tailored security checklist. No prior knowledge of security standards needed.</p>
            </div>
        </div>
    </div>
</section>

<SectionDivider Inverted="true" />

<!-- FEATURES CAROUSEL SECTION -->
<section class="cc-features-carousel-section">

    <div class="cc-features-carousel-header">
        <span class="cc-carousel-label-tag">What you can do</span>
        <h2 class="cc-why-choose-section-title">
            Ready to Get
            <span class="carousel-gradient-text">Started?</span>
        </h2>
        <h5 class="cc-why-choose-section-subtitle">Choose your path to secure healthcare web application development</h5>
    </div>

    <div class="cc-carousel-outer">
        <div class="cc-carousel-viewport"
             style="-webkit-mask-image: @CarouselMaskStyle; mask-image: @CarouselMaskStyle;">

            <div class="cc-carousel-track" style="--slide-index: @currentSlide;">

                <!-- CARD 1 — ASVS -->
                <div class="cc-service-card">
                    <div class="cc-service-card-top">
                        <div class="cc-service-card-icon-wrap cc-service-card-icon-wrap--teal">
                            <MudIcon Icon="@Icons.Material.Filled.Security" Style="color:#34acd8;font-size:22px;" />
                        </div>
                        <span class="cc-service-card-tag cc-service-card-tag--teal">ASVS</span>
                    </div>
                    <h1 class="cc-service-card-title">Explore OWASP<br />ASVS 5.0</h1>
                    <p class="cc-service-card-desc">Browse and understand all OWASP ASVS 5.0 requirements, carefully organized by chapters and status.</p>
                    <div class="cc-service-card-footer">
                        <span class="cc-service-card-metric">500+</span>
                        <span class="cc-service-card-metric-label">requirements</span>
                    </div>
                    <MudButton Variant="Variant.Outlined"
                               Class="cc-carousel-card-btn cc-carousel-card-btn--outlined"
                               OnClick="@(() => NavService.NavigateTo("/asvs-requirements"))">
                        <span>View Requirements</span>
                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Class="ml-2" />
                    </MudButton>
                </div>

                <!-- CARD 2 — WSTG -->
                <div class="cc-service-card">
                    <div class="cc-service-card-top">
                        <div class="cc-service-card-icon-wrap cc-service-card-icon-wrap--purple">
                            <MudIcon Icon="@Icons.Material.Filled.Assignment" Style="color:#7483f3;font-size:22px;" />
                        </div>
                        <span class="cc-service-card-tag cc-service-card-tag--purple">WSTG</span>
                    </div>
                    <h1 class="cc-service-card-title">Explore OWASP<br />WSTG Tests</h1>
                    <p class="cc-service-card-desc">Browse the full OWASP WSTG, organized by category.</p>
                    <div class="cc-service-card-footer">
                        <span class="cc-service-card-metric">200+</span>
                        <span class="cc-service-card-metric-label">tests</span>
                    </div>
                    <MudButton Variant="Variant.Outlined"
                               Class="cc-carousel-card-btn cc-carousel-card-btn--outlined"
                               OnClick="@(() => NavService.NavigateTo("/wstg-tests"))">
                        <span>View tests</span>
                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Class="ml-2" />
                    </MudButton>
                </div>

                <!-- CARD 3 — Security Level -->
                <div class="cc-service-card">
                    <div class="cc-service-card-top">
                        <div class="cc-service-card-icon-wrap cc-service-card-icon-wrap--blue">
                            <MudIcon Icon="@Icons.Material.Filled.Shield" Style="color:#4e8de8;font-size:22px;" />
                        </div>
                        <span class="cc-service-card-tag cc-service-card-tag--blue">Security Level</span>
                    </div>
                    <h1 class="cc-service-card-title">Choose Your<br />Security Level</h1>
                    <p class="cc-service-card-desc">Based on our workflow, choose the security level that best fits your healthcare web application's architecture and risk exposure.</p>
                    <div class="cc-service-card-footer">
                        <span class="cc-service-card-metric">3</span>
                        <span class="cc-service-card-metric-label">ASVS levels available</span>
                    </div>
                    <MudButton Variant="Variant.Outlined"
                               Class="cc-carousel-card-btn cc-carousel-card-btn--outlined"
                               OnClick="@(() => NavService.NavigateTo("/security-level"))">
                        <span>Security Level</span>
                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Class="ml-2" />
                    </MudButton>
                </div>

                <!-- CARD 4 — Questionnaire -->
                <div class="cc-service-card">
                    <div class="cc-service-card-top">
                        <div class="cc-service-card-icon-wrap cc-service-card-icon-wrap--teal">
                            <MudIcon Icon="@Icons.Material.Filled.Quiz" Style="color:#34acd8;font-size:22px;" />
                        </div>
                        <span class="cc-service-card-tag cc-service-card-tag--teal">Questionnaire</span>
                    </div>
                    <h1 class="cc-service-card-title">Generate Your<br />Requirements</h1>
                    <p class="cc-service-card-desc">Answer a short questionnaire about your app and instantly get a tailored checklist of ASVS requirements and WSTG test cases.</p>
                    <div class="cc-service-card-footer">
                        <span class="cc-service-card-metric">5 min</span>
                        <span class="cc-service-card-metric-label">average setup time</span>
                    </div>
                    <MudButton Variant="Variant.Filled"
                               Class="cc-carousel-card-btn cc-carousel-card-btn--filled"
                               OnClick="HandleGoToProfile">
                        <span>Start Questionnaire</span>
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="ml-2" />
                    </MudButton>
                </div>

            </div>
        </div>

        <!-- FRECCIA SINISTRA -->
        <button class="cc-carousel-arrow cc-carousel-arrow--left"
                @onclick="PrevSlide"
                disabled="@(currentSlide == 0)">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
        </button>

        <!-- FRECCIA DESTRA -->
        <button class="cc-carousel-arrow cc-carousel-arrow--right"
                @onclick="NextSlide"
                disabled="@(currentSlide >= MaxSlide)">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </button>
    </div>

    <!-- DOTS -->
    <div class="cc-carousel-dots">
        @for (int i = 0; i <= MaxSlide; i++)
        {
            var dotIdx = i;
            <button class="cc-carousel-dot @(currentSlide == dotIdx ? "cc-carousel-dot--active" : "")"
                    @onclick="() => GoToSlide(dotIdx)">
            </button>
        }
    </div>

</section>

<SectionDivider Flip="true" />

@code {
    private bool animate;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            animate = true;
            StateHasChanged();
        }
    }

    private async Task HandleGoToProfile()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity!.IsAuthenticated)
        {
            await NavService.NavigateTo("/account/profile");
        }
        else
        {
            await NavService.NavigateTo("/account/login", true);
        }
    }

    private int currentSlide = 0;
    private const int MaxSlide = 3;

    private string CarouselMaskStyle =>
        $"linear-gradient(to right, " +
        $"{(currentSlide == 0 ? "black 0%" : "transparent 0%, black 10%")}, " +
        $"black {(currentSlide == MaxSlide ? "100%" : "90%")}, " +
        $"{(currentSlide == MaxSlide ? "black 100%" : "transparent 100%")})";

    private void NextSlide() { if (currentSlide < MaxSlide) currentSlide++; }
    private void PrevSlide() { if (currentSlide > 0) currentSlide--; }
    private void GoToSlide(int index) { currentSlide = index; }
}
