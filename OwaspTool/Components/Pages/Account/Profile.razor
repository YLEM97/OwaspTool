@page "/account/profile"
@using System.Security.Claims
@using AuthLibrary.Areas.Auth.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using MudBlazor
@using OwaspTool.Components.Shared
@attribute [Authorize]

@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IUserWebAppRepository UserWebAppRepository
@inject IDialogService DialogService

<PageTitle>Profile — CureCode</PageTitle>

<div class="profile-page">

    <!-- HERO -->
    <div class="profile-hero">
        <div class="profile-hero-bg"></div>
        <div class="profile-avatar-wrapper">
            <MudAvatar Class="profile-avatar">
                <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size: 3rem; color: #34acd8;" />
            </MudAvatar>
            <div class="profile-avatar-badge">
                <MudIcon Icon="@Icons.Material.Filled.Verified" Style="font-size: 1rem; color: #34acd8;" />
            </div>
        </div>
        <div class="profile-hero-info">
            <h1 class="profile-name">@FirstName @LastName</h1>
            <span class="profile-role-badge">
                <MudIcon Icon="@Icons.Material.Filled.Shield" Style="font-size: 14px; margin-right: 6px;" />
                User
            </span>
            <p class="profile-joined">@Email</p>
        </div>
    </div>

    <!-- PANELS -->
    <div class="profile-panels">
        <MudExpansionPanels Elevation="0" ExpandMultiple="true" Class="profile-expansion">

            <!-- PANEL 1: PROFILE INFO -->
            <MudExpansionPanel Class="profile-panel" DisableRipple="true">
                <TitleContent>
                    <div class="profile-panel-title">
                        <div class="profile-panel-icon profile-panel-icon--blue">
                            <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" />
                        </div>
                        <div>
                            <div class="profile-panel-label">Account</div>
                            <div class="profile-panel-heading">Profile information</div>
                        </div>
                    </div>
                </TitleContent>
                <ChildContent>
                    <div class="profile-fields">

                        <div class="profile-field">
                            <div class="profile-field-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" />
                            </div>
                            <div class="profile-field-content">
                                <span class="profile-field-label">First name</span>
                                <span class="profile-field-value">@FirstName</span>
                            </div>
                        </div>

                        <div class="profile-field">
                            <div class="profile-field-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" />
                            </div>
                            <div class="profile-field-content">
                                <span class="profile-field-label">Last name</span>
                                <span class="profile-field-value">@LastName</span>
                            </div>
                        </div>

                        <div class="profile-field">
                            <div class="profile-field-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Email" />
                            </div>
                            <div class="profile-field-content">
                                <span class="profile-field-label">Email address</span>
                                <span class="profile-field-value">@Email</span>
                            </div>
                            <MudChip T="string" Size="Size.Small" Class="profile-chip profile-chip--verified">Verified</MudChip>
                        </div>

                        <!-- CHANGE PASSWORD -->
                        <div class="profile-fields-footer">
                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.Key"
                                       Class="profile-edit-btn"
                                       OnClick="@ShowChangePassword">
                                Change Password
                            </MudButton>
                        </div>

                        @if (ShowPasswordFields)
                        {
                            <div class="profile-password-fields">
                                <div class="cc-field-group">
                                    <label class="cc-field-label">Current Password</label>
                                    <MudTextField @bind-Value="CurrentPassword"
                                                  InputType="@(ShowCurrentPassword? InputType.Text: InputType.Password)"
                                                  Required="true"
                                                  Variant="Variant.Outlined"
                                                  Adornment="Adornment.End"
                                                  AdornmentIcon="@(ShowCurrentPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                  OnAdornmentClick="@(() => ShowCurrentPassword = !ShowCurrentPassword)"
                                                  Class="cc-password-field" />
                                </div>

                                <div class="cc-field-group">
                                    <label class="cc-field-label">New Password</label>
                                    <MudTextField @bind-Value="NewPassword"
                                                  InputType="@(ShowNewPassword? InputType.Text: InputType.Password)"
                                                  Required="true"
                                                  Variant="Variant.Outlined"
                                                  Adornment="Adornment.End"
                                                  AdornmentIcon="@(ShowNewPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                  OnAdornmentClick="@(() => ShowNewPassword = !ShowNewPassword)"
                                                  Class="cc-password-field" />
                                </div>

                                <div class="cc-field-group">
                                    <label class="cc-field-label">Confirm New Password</label>
                                    <MudTextField @bind-Value="ConfirmPassword"
                                                  InputType="@(ShowConfirmPassword? InputType.Text: InputType.Password)"
                                                  Required="true"
                                                  Variant="Variant.Outlined"
                                                  Adornment="Adornment.End"
                                                  AdornmentIcon="@(ShowConfirmPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                  OnAdornmentClick="@(() => ShowConfirmPassword = !ShowConfirmPassword)"
                                                  Validation="@((Func<string, string>)(v => v == NewPassword ? null : "Passwords do not match"))"
                                                  Class="cc-password-field" />
                                </div>


                                @if (ChangePasswordErrors.Any())
                                {
                                    <div class="cc-auth-alert cc-auth-alert--error" style="margin-bottom: 8px; align-items: flex-start;">
                                        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline"
                                                 Style="font-size:18px; margin-right:10px; flex-shrink:0; margin-top: 2px;" />
                                        <ul style="margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 4px;">
                                            @foreach (var error in ChangePasswordErrors)
                                            {
                                                <li>@error</li>
                                            }
                                        </ul>
                                    </div>
                                }

                                <MudButton OnClick="@AskConfirmChangePassword"
                                           Variant="Variant.Filled"
                                           Class="profile-save-btn">
                                    SUBMIT
                                </MudButton>
                            </div>
                        }

                    </div>
                </ChildContent>
            </MudExpansionPanel>

            <!-- PANEL 2: YOUR APPLICATIONS -->
            <MudExpansionPanel Class="profile-panel" DisableRipple="true">
                <TitleContent>
                    <div class="profile-panel-title">
                        <div class="profile-panel-icon profile-panel-icon--violet">
                            <MudIcon Icon="@Icons.Material.Filled.Apps" />
                        </div>
                        <div>
                            <div class="profile-panel-label">System</div>
                            <div class="profile-panel-heading">Your applications</div>
                        </div>
                        <MudSpacer />
                        <span class="profile-panel-count">@(UserApps?.Count ?? 0) apps</span>
                    </div>
                </TitleContent>
                <ChildContent>
                    <div class="apps-table-wrapper">

                        @if (UserApps is null)
                        {
                            <MudProgressCircular Indeterminate="true" />
                        }
                        else if (!UserApps.Any())
                        {
                            <MudText Typo="Typo.body1" Class="mb-4" Style="color: rgba(255,255,255,0.6);">
                                You haven't added any applications yet.
                            </MudText>
                        }
                        else
                        {
                            <!-- HEADER -->
                            <div class="apps-table-header">
                                <div class="apps-col apps-col--name">Application name</div>
                                <div class="apps-col apps-col--level">Security level</div>
                                <div class="apps-col apps-col--actions">Actions</div>
                            </div>

                            <!-- ROWS -->
                            @foreach (var app in UserApps)
                            {
                                <div class="apps-table-row">

                                    <!-- NAME -->
                                    <div class="apps-col apps-col--name">
                                        <div class="apps-name-icon">
                                            <MudIcon Icon="@Icons.Material.Filled.WebAsset" />
                                        </div>
                                        <div>
                                            <div class="apps-name">@app.Name</div>
                                            <div class="apps-name-sub">
                                                @(app.IsSurveyCompleted ? "Survey completed" : "Survey pending")
                                            </div>
                                        </div>
                                    </div>

                                    <!-- LEVEL -->
                                    <div class="apps-col apps-col--level">
                                        <span class="apps-level-badge apps-level-badge--@GetLevelClass(app.LevelAcronym)">
                                            <MudIcon Icon="@Icons.Material.Filled.Security"
                                                     Style="font-size:14px; margin-right:5px;" />
                                            @(string.IsNullOrWhiteSpace(app.LevelLabel) ? app.LevelAcronym : app.LevelLabel)
                                        </span>
                                    </div>

                                    <!-- ACTIONS -->
                                    <div class="apps-col apps-col--actions">

                                        <MudIconButton Icon="@Icons.Material.Filled.QuestionAnswer"
                                                       Class="@($"apps-action-btn {(app.IsSurveyCompleted ? "apps-action-btn--done" : "apps-action-btn--survey")}")"
                                                       Size="Size.Small"
                                                       Href="@($"/survey/{app.UserWebAppID}")"
                                                       Title="@(app.IsSurveyCompleted ? "View survey" : "Start survey")" />

                                        @if (app.IsSurveyCompleted)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.ListAlt"
                                                           Class="apps-action-btn apps-action-btn--asvs"
                                                           Size="Size.Small"
                                                           Href="@($"/survey/{app.UserWebAppID}/requirements")"
                                                           Title="OWASP ASVS requirements" />

                                            <MudIconButton Icon="@Icons.Material.Filled.FactCheck"
                                                           Class="apps-action-btn apps-action-btn--wstg"
                                                           Size="Size.Small"
                                                           Href="@($"/survey/{app.UserWebAppID}/wstg-tests")"
                                                           Title="OWASP WSTG tests" />
                                        }

                                        <div style="flex:1;" />

                                        <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                                                       Class="apps-action-btn apps-action-btn--delete"
                                                       Size="Size.Small"
                                                       Title="Delete application"
                                                       OnClick="@(() => ConfirmDelete(app.UserWebAppID))" />
                                    </div>

                                </div>
                            }

                            <!-- LEGENDA -->
                            <div class="apps-legend">
                                <span class="apps-legend-title">Actions legend:</span>
                                <div class="apps-legend-items">
                                    <div class="apps-legend-item">
                                        <div class="apps-legend-icon apps-legend-icon--pending">
                                            <MudIcon Icon="@Icons.Material.Filled.QuestionAnswer" Style="font-size:16px;" />
                                        </div>
                                        <span>Survey (pending)</span>
                                    </div>
                                    <div class="apps-legend-item">
                                        <div class="apps-legend-icon apps-legend-icon--done">
                                            <MudIcon Icon="@Icons.Material.Filled.QuestionAnswer" Style="font-size:16px;" />
                                        </div>
                                        <span>Survey (completed)</span>
                                    </div>
                                    <div class="apps-legend-item">
                                        <div class="apps-legend-icon apps-legend-icon--asvs">
                                            <MudIcon Icon="@Icons.Material.Filled.ListAlt" Style="font-size:16px;" />
                                        </div>
                                        <span>OWASP ASVS requirements</span>
                                    </div>
                                    <div class="apps-legend-item">
                                        <div class="apps-legend-icon apps-legend-icon--wstg">
                                            <MudIcon Icon="@Icons.Material.Filled.FactCheck" Style="font-size:16px;" />
                                        </div>
                                        <span>OWASP WSTG tests</span>
                                    </div>
                                    <div class="apps-legend-item">
                                        <div class="apps-legend-icon apps-legend-icon--delete">
                                            <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Style="font-size:16px;" />
                                        </div>
                                        <span>Delete application</span>
                                    </div>
                                </div>
                                <p class="apps-legend-note">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Style="font-size:14px; margin-right:5px; color:#34acd8;" />
                                    ASVS and WSTG buttons appear only after the survey is completed.
                                </p>
                            </div>
                        }

                        <!-- FOOTER -->
                        <div class="apps-table-footer">
                            <MudButton StartIcon="@Icons.Material.Filled.AddCircleOutline"
                                       Class="apps-add-btn"
                                       Variant="Variant.Text"
                                       Href="/web-application-registry">
                                Add a new application
                            </MudButton>
                        </div>

                    </div>
                </ChildContent>
            </MudExpansionPanel>

        </MudExpansionPanels>
    </div>
</div>



@code {
    private string FirstName = "";
    private string LastName = "";
    private string Email = "";

    private bool ProfileExpanded = false;
    private bool AppExpanded = false;
    private bool ShowPasswordFields = false;

    private bool ShowCurrentPassword = false;
    private bool ShowNewPassword = false;
    private bool ShowConfirmPassword = false;

    private string CurrentPassword = "";
    private string NewPassword = "";
    private string ConfirmPassword = "";

    private List<string> ChangePasswordErrors = new();

    private ApplicationUser? UserEntity;
    private List<UserWebAppDTO>? UserApps;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;

        FirstName = user.FindFirst("Name")?.Value ?? "";
        LastName = user.FindFirst("Surname")?.Value ?? "";
        Email = user.FindFirst(ClaimTypes.Email)?.Value ?? "";

        UserEntity = await UserManager.GetUserAsync(user);

        if (!string.IsNullOrWhiteSpace(Email))
        {
            UserApps = await UserWebAppRepository.GetAllByUserAsync(Email);

            // Determine completed flag per app (sequential to avoid DbContext conflicts)
            foreach (var uwa in UserApps)
            {
                uwa.IsSurveyCompleted = await UserWebAppRepository.IsSurveyCompletedAsync(uwa.UserWebAppID);
            }
        }
        else
        {
            UserApps = new List<UserWebAppDTO>();
        }
    }

    private void ToggleProfileExpanded() => ProfileExpanded = !ProfileExpanded;
    private void ToggleAppExpanded() => AppExpanded = !AppExpanded;

    private void ShowChangePassword() => ShowPasswordFields = true;

    private async Task AskConfirmChangePassword()
    {
        // Validazioni preliminari prima di aprire il modal
        ChangePasswordErrors = new();

        if (string.IsNullOrWhiteSpace(CurrentPassword) ||
            string.IsNullOrWhiteSpace(NewPassword) ||
            string.IsNullOrWhiteSpace(ConfirmPassword))
        {
            ChangePasswordErrors.Add("Please fill in all password fields.");
            return;
        }

        if (NewPassword != ConfirmPassword)
        {
            ChangePasswordErrors.Add("New passwords do not match.");
            return;
        }

        // Se le validazioni passano, apre il modal
        var dialog = await DialogService.ShowAsync<ConfirmPasswordChangeDialog>(
            string.Empty,
            new DialogOptions
            {
                CloseButton = false,
                MaxWidth = MaxWidth.ExtraSmall,
                FullWidth = true,
                BackdropClick = false
            }
        );

        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await ExecuteChangePassword();
        }
    }

    private async Task ExecuteChangePassword()
    {
        var passwordCheck = await UserManager.CheckPasswordAsync(UserEntity!, CurrentPassword);
        if (!passwordCheck)
        {
            ChangePasswordErrors.Add("Current password is incorrect.");
            return;
        }

        foreach (var validator in UserManager.PasswordValidators)
        {
            var validationResult = await validator.ValidateAsync(UserManager, UserEntity!, NewPassword);
            if (!validationResult.Succeeded)
            {
                ChangePasswordErrors.AddRange(validationResult.Errors.Select(e => e.Description));
                return;
            }
        }

        var result = await UserManager.ChangePasswordAsync(UserEntity!, CurrentPassword, NewPassword);

        if (result.Succeeded)
        {
            Navigation.NavigateTo("/account/password-changed", true);
            return;
        }

        ChangePasswordErrors.AddRange(result.Errors.Select(e => e.Description));
    }

    private async Task ConfirmDelete(int userWebAppId)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>(
            string.Empty,
            new DialogOptions
            {
                CloseButton = false,
                MaxWidth = MaxWidth.ExtraSmall,
                FullWidth = true,
                BackdropClick = false
            }
        );

        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await DeleteConfirmed(userWebAppId);
        }
    }

    private async Task DeleteConfirmed(int userWebAppId)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(Email))
            {
                Snackbar.Add("Unable to determine user email for deletion.", Severity.Error);
                return;
            }

            await UserWebAppRepository.DeleteAsync(userWebAppId, Email);

            // reload user apps and completion flags
            UserApps = await UserWebAppRepository.GetAllByUserAsync(Email);
            foreach (var uwa in UserApps)
            {
                uwa.IsSurveyCompleted = await UserWebAppRepository.IsSurveyCompletedAsync(uwa.UserWebAppID);
            }

            Snackbar.Add("Application deleted", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    private string GetLevelClass(string? acronym) => acronym?.ToLower() switch
    {
        "l1" => "1",
        "l2" => "2",
        "l3" => "3",
        _ => "1"
    };

}
