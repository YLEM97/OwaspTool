@page "/reset-password"
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="cc-auth-page">
    <div class="cc-auth-bg-glow cc-auth-bg-glow--left"></div>
    <div class="cc-auth-bg-glow cc-auth-bg-glow--right"></div>

    <div class="cc-auth-card cc-auth-card-resetpassword">

        <!-- HEADER -->
        <div class="cc-auth-card-header">
            <div class="cc-auth-card-icon">
                <img src="img/logo_CureCode.png"
                     alt="CureCode"
                     style="height:36px;width:auto;margin-right:8px;" />
            </div>
            <h1 class="cc-auth-title">Choose a new password</h1>
            <p class="cc-auth-subtitle">Almost there — just set your new password</p>
        </div>

        <div class="authlib-reset authlib-reset-pwd">
            <ResetPasswordComponent id="@id" />
        </div>

    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? id { get; set; }

    private IJSObjectReference? _jsModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./js/passwordToggle.js");
                await _jsModule.InvokeVoidAsync("initPasswordToggles");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[cc] JS init failed: {ex.Message}");
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            try { await _jsModule.DisposeAsync(); }
            catch (JSDisconnectedException) { } 
        }
    }
}