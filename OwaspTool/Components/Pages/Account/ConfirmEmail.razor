@page "/confirm-email/{userId}/{token}"
@inject NavigationManager Navigation


<div class="cc-auth-page">
    <div class="cc-auth-bg-glow cc-auth-bg-glow--left"></div>
    <div class="cc-auth-bg-glow cc-auth-bg-glow--right"></div>

    <div class="cc-auth-card">
        <div class="cc-auth-card__header">
            <img src="img/logo_CureCode.png"
                 alt="CureCode"
                 style="height:36px;width:auto;margin-right:8px;" />
        </div>

        <div class="cc-auth-card__body authlib-confirm">
            <div class="authlib-form-container">
                <ConfirmEmailComponent userId="@userId" token="@token"></ConfirmEmailComponent>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? userId { get; set; }
    [Parameter] public string? token { get; set; }

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
    }
}
