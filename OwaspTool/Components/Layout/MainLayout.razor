@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using OwaspTool.Components.Shared
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="_customTheme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<GlobalTransitionOverlay />

<div class="layout-wrapper">

    <NavMenu IsLoggedIn="@IsLoggedIn" UserName="@UserName" />

    <main class="cc-main">
        @Body
    </main>

</div>

<div class="cc-cookie-fab">
    <MudIconButton Icon="@Icons.Material.Filled.Cookie"
                   Color="Color.Secondary"
                   Size="Size.Large"
                   @onclick="OpenCookieConsentPanelAsync" />
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool IsLoggedIn;
    private string? UserName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        IsLoggedIn = user?.Identity != null && user.Identity.IsAuthenticated;

        if (IsLoggedIn)
        {
            var firstName = user?.FindFirst("Name")?.Value ?? "";
            var lastName = user?.FindFirst("Surname")?.Value ?? "";
            UserName = $"{firstName} {lastName}".Trim();
        }
    }

    private MudTheme _customTheme = new MudTheme()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#34acd8",
            Secondary = "#7483f3",
            Tertiary = "#4e53b3",
            Info = "#1d53a1",
            Background = "#07193e",
            Surface = "#0d2454",
            AppbarBackground = "#07193e",
            AppbarText = "#ffffff",
            DrawerBackground = "#07193e",
            DrawerText = "#ffffff",
            TextPrimary = "#ffffff",
            TextSecondary = "rgba(255,255,255,0.65)",
            ActionDefault = "#ffffff",
            LinesDefault = "rgba(255,255,255,0.08)",
            TableHover = "rgba(52,172,216,0.08)",
            Error = "#E76F51",
        }
    };

    [Inject] private BytexDigital.Blazor.Components.CookieConsent.CookieConsentService CookieConsentService { get; set; } = default!;

    private async Task OpenCookieConsentPanelAsync()
    {
        await CookieConsentService.ShowPreferencesModalAsync();
    }
}
