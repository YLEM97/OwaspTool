@using MudBlazor
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer
@inject NavigationManager Navigation

<header class="cc-appbar @(_scrolled ? "cc-appbar--scrolled" : "")">
    <div class="cc-appbar-container">

        <!-- LOGO -->
        <a href="/" class="cc-appbar-logo-link">
            <img src="img/logo_CureCode.png" alt="CureCode" class="cc-appbar-logo" />
        </a>

        <!-- LINKS DESKTOP -->
        <nav class="cc-nav-links">
            <a href="/" class="cc-nav-link @(IsActive("/") ? "cc-nav-link--active" : "")">Home</a>
            <a href="/security-level" class="cc-nav-link @(IsActive("/security-level") ? "cc-nav-link--active" : "")">Security Level</a>
            <a href="/asvs-requirements" class="cc-nav-link @(IsActive("/asvs-requirements") ? "cc-nav-link--active" : "")">ASVS</a>
            <a href="/wstg-tests" class="cc-nav-link @(IsActive("/wstg-tests") ? "cc-nav-link--active" : "")">WSTG</a>
        </nav>

        <div class="cc-appbar-spacer"></div>

        <!-- AUTH DESKTOP -->
        <div class="cc-auth-actions cc-auth-desktop">
            @if (IsLoggedIn)
            {
                <span class="cc-auth-hello">Hi, @UserName!</span>
                <a href="/account/profile" class="cc-icon-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </a>
                <a href="/account/confirm-logout" class="cc-pill-btn cc-pill-btn--logout">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                         style="margin-right:6px">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    LOGOUT
                </a>
            }
            else
            {
                <a href="/account/login" class="cc-pill-btn cc-pill-btn--login">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                         style="margin-right:6px">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                        <polyline points="10 17 15 12 10 7" />
                        <line x1="15" y1="12" x2="3" y2="12" />
                    </svg>
                    LOGIN
                </a>
                <a href="/account/register" class="cc-pill-btn cc-pill-btn--register">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                         style="margin-right:6px">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="8.5" cy="7" r="4" />
                        <line x1="20" y1="8" x2="20" y2="14" />
                        <line x1="23" y1="11" x2="17" y2="11" />
                    </svg>
                    REGISTER
                </a>
            }
        </div>

        <!-- BURGER MOBILE -->
        <button class="cc-burger @(_menuOpen ? "cc-burger--open" : "")"
                @onclick="ToggleMenu" aria-label="Menu">
            <span class="cc-burger-line"></span>
            <span class="cc-burger-line"></span>
            <span class="cc-burger-line"></span>
        </button>

    </div>
</header>

<!-- OVERLAY -->
<div class="cc-overlay @(_menuOpen ? "cc-overlay--visible" : "")"
     @onclick="CloseMenu"></div>

<!-- DRAWER MOBILE -->
<nav class="cc-drawer @(_menuOpen ? "cc-drawer--open" : "")">

    <div class="cc-drawer-head">
        <img src="img/logo_CureCode.png" alt="CureCode" style="height:36px;width:auto;" />
        <button class="cc-drawer-close" @onclick="CloseMenu" aria-label="Chiudi">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
        </button>
    </div>

    <div class="cc-drawer-links">
        <a href="/" class="cc-drawer-link @(IsActive("/") ? "cc-drawer-link--active" : "")"
           @onclick="CloseMenu">Home</a>
        <a href="/security-level" class="cc-drawer-link @(IsActive("/security-level") ? "cc-drawer-link--active" : "")"
           @onclick="CloseMenu">Security Level</a>
        <a href="/asvs-requirements" class="cc-drawer-link @(IsActive("/asvs-requirements") ? "cc-drawer-link--active" : "")"
           @onclick="CloseMenu">ASVS</a>
        <a href="/wstg-tests" class="cc-drawer-link @(IsActive("/wstg-tests") ? "cc-drawer-link--active" : "")"
           @onclick="CloseMenu">WSTG</a>
    </div>

    <div class="cc-drawer-auth">
        @if (IsLoggedIn)
        {
            <span class="cc-drawer-hello">Hi, @UserName!</span>
            <a href="/account/profile" class="cc-pill-btn cc-pill-btn--login" @onclick="CloseMenu">
                PROFILE
            </a>
            <a href="/account/confirm-logout" class="cc-pill-btn cc-pill-btn--logout" @onclick="CloseMenu">
                LOGOUT
            </a>
        }
        else
        {
            <a href="/account/login" class="cc-pill-btn cc-pill-btn--login" @onclick="CloseMenu">
                LOGIN
            </a>
            <a href="/account/register" class="cc-pill-btn cc-pill-btn--register" @onclick="CloseMenu">
                REGISTER
            </a>
        }
    </div>

</nav>

@code {
    [Parameter] public bool IsLoggedIn { get; set; }
    [Parameter] public string? UserName { get; set; }

    private bool _scrolled = false;
    private bool _menuOpen = false;
    private bool _isInteractive = false;
    private DotNetObjectReference<NavMenu>? _objRef;

    private bool IsActive(string href)
    {
        var current = "/" + Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/');
        if (href == "/") return current == "/";
        return current.StartsWith(href, StringComparison.OrdinalIgnoreCase);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isInteractive = true;
            _objRef = DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("registerScrollHandler", _objRef);
            }
            catch (JSException) { }
            catch (InvalidOperationException) { }
        }
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;

    [JSInvokable]
    public void OnScroll(bool isScrolled)
    {
        _scrolled = isScrolled;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_isInteractive)
        {
            try { await JS.InvokeVoidAsync("unregisterScrollHandler"); }
            catch (JSDisconnectedException) { }
            catch (TaskCanceledException) { }
        }
        _objRef?.Dispose();
    }
}
