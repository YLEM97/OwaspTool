@using MudBlazor

<MudDialog>
    <TitleContent>
        <div style="display: flex; align-items: center; gap: 10px;">
            <MudIcon Icon="@Icons.Material.Filled.WarningAmber"
                     Style="color: #f59e0b; font-size: 26px;" />
            <span style="font-weight: 700; font-size: 1.1rem;">Confirm password change</span>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1" Style="margin-bottom: 8px;">
            You are about to change your password.
        </MudText>
        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.6);">
            For security reasons, you will be <strong>signed out immediately</strong> after this action
            and will need to log in again with your new password.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Outlined"
                   Style="border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.6);">
            Cancel
        </MudButton>
        <MudButton OnClick="Confirm"
                   Variant="Variant.Filled"
                   Style="background: #34acd8; color: #ffffff; font-weight: 700;">
            Yes, change password
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
