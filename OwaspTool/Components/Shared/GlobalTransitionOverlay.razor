@inject NavigationService NavService
@implements IDisposable

@if (NavService.IsNavigating)
{
    <div class="cc-page-transition-overlay" style="background-color:#07193e;">
        <div class="cc-transition-content">
            <div class="tcc-ransition-logo-wrap">
                <img src="img/logo_CureCode.png"
                     alt="CureCode"
                     style="height: 52px; width: auto; margin-right:8px;" />
            </div>
            <div class="cc-transition-title">
                Please wait
                <div class="cc-loading-dots">
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        NavService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        NavService.OnChange -= StateHasChanged;
    }
}
