@code {
    private bool _isPulsing = false;
    private bool _tagOpened = false;
    private bool _isRendered = false;

    private string GetTagLeftClass()
    {
        var classes = new List<string>();
        if (_isPulsing) classes.Add("tag-pulse");
        if (_tagOpened) classes.Add("tag-left-open");
        return string.Join(" ", classes);
    }

    private string GetTagRightClass()
    {
        var classes = new List<string>();
        if (_isPulsing) classes.Add("tag-pulse");
        if (_tagOpened) classes.Add("tag-right-open");
        return string.Join(" ", classes);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isRendered)
        {
            _isRendered = true;

            await Task.Delay(400);

            // Prima pulsazione
            _isPulsing = true;
            StateHasChanged();
            await Task.Delay(500);
            _isPulsing = false;
            StateHasChanged();
            await Task.Delay(150);

            // Seconda pulsazione
            _isPulsing = true;
            StateHasChanged();
            await Task.Delay(500);
            _isPulsing = false;
            StateHasChanged();
            await Task.Delay(200);

            _tagOpened = true;
            StateHasChanged();
        }
    }
}